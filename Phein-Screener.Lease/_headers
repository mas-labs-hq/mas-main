# Security headers + no-cache for HTML/JS
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Cache-Control: no-cache, no-store, must-revalidate
  Content-Security-Policy: default-src 'self' 'unsafe-inline' 'unsafe-eval' https://formspree.io https://cdnjs.cloudflare.com https://fonts.googleapis.com https://fonts.gstatic.com; frame-src https://formspree.io; connect-src https://formspree.io; img-src 'self' data: blob:; font-src 'self' https://fonts.gstatic.com data:

